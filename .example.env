# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tp
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tp_test

# Auth
SECRET_JWT_SIGNING_KEY=change-this-to-a-secret-key-min-16-chars
JWT_EXPIRATION_TIME_IN_HOURS=24

# CORS (JSON array, pydantic-settings requires JSON for list types)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_AS_JSON=false
